# ── Database (PostgreSQL) ──
DATABASE_URL="postgresql://olive:YOUR_PASSWORD@postgres:5432/olive_labs"

# ── Redis ──
REDIS_URL="redis://redis:6379"

# ── MinIO (S3-compatible storage) ──
MINIO_ENDPOINT="minio"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minio_access_key"
MINIO_SECRET_KEY="YOUR_MINIO_SECRET"
MINIO_USE_SSL=false
MINIO_BUCKET_PDFS="propostas-pdf"
MINIO_BUCKET_ATTACHMENTS="attachments"
MINIO_BUCKET_LOGOS="logos"

# ── NextAuth ──
NEXTAUTH_SECRET="generate-a-random-secret-min-32-chars"
NEXTAUTH_URL="https://your-domain.com"
